<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	
	<key>CFBundleDisplayName</key>
	<string>Backpackr</string>
	
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	
	<key>CFBundleName</key>
	<string>Backpackr</string>
	
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	
	<key>CFBundleSignature</key>
	<string>????</string>
	
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	
	<key>LSRequiresIPhoneOS</key>
	<true/>
	
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	
	<key>NSCameraUsageDescription</key>
	<string>The camera permission allows the app to access your device's camera to capture photos within the app. This is used when you want to take pictures for your profile, posts, or during content creation. It ensures a seamless media-capturing experience without leaving the app.</string>
	
	<key>NSPhotoLibraryUsageDescription</key>
	<string>The gallery permission lets the app access your photos, and media files stored on your device. It's required when you upload existing images. This helps you easily select and manage media from your device within the app.</string>

	<key>NSLocationWhenInUseUsageDescription</key>
	<string>The location permission allows the app to determine your current location using GPS or network services. This helps provide personalized features like suggesting nearby users, destinations, or tagging your location in posts. It enhances your overall app experience by enabling location-based recommendations.</string>
	

	<key>UIFileSharingEnabled</key>
    <true/>
    
	<key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>


	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	
	<key>UIRequiresFullScreen</key>
	<true/>
	
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	
	<key>io.flutter.embedded_views_preview</key>
	<true/>
</dict>
</plist>
