# =================================================================
# BACKPACKR ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in the values below.
# =================================================================

# --- AWS BACKEND ---
# The base URL for your AWS image upload service
AWS_UPLOAD_BASE_URL=

# --- IN-APP PURCHASES (IAP) ---
# The Product ID for the Lifetime Premium Membership
IAP_LIFETIME_PREMIUM_ID=

# The Product ID for testing (Sandbox)
IAP_PREMIUM_TEST_ID=

# The Product ID for testing consumable "Trophies"
IAP_TROPHIES_TEST_ID=

# NOTE: Firebase configuration is handled natively via google-services.json 
# and GoogleService-Info.plist. Refer to the .example files in those 
# directories for setup instructions.
