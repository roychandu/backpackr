# =================================================================
# BACKPACKR ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in the values.
# =================================================================

# --- AWS BACKEND ---
# The base URL for your AWS image upload service
AWS_UPLOAD_BASE_URL=https://rest.yuvonglobe-app.info/

# --- IN-APP PURCHASES (IAP) ---
# The Product ID for the Lifetime Premium Membership (App Store / Play Store)
IAP_LIFETIME_PREMIUM_ID=com.birtansokullu.preglob

# The Product ID for testing (Sandbox)
IAP_PREMIUM_TEST_ID=com.test.bet

# The Product ID for testing consumable "Trophies"
IAP_TROPHIES_TEST_ID=com.backpackr.10006

# --- FIREBASE & GOOGLE SERVICES ---
# The API Key from GoogleService-Info.plist (iOS)
FIREBASE_API_KEY_IOS=

# The API Key from google-services.json (Android)
FIREBASE_API_KEY_ANDROID=

# Your Firebase Project ID (e.g., backpackr-a3499)
FIREBASE_PROJECT_ID=backpackr-a3499

# Your Firebase Messaging Sender ID (GCM Sender ID)
FIREBASE_MESSAGING_SENDER_ID=148983027806
